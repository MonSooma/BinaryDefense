[node name="Information" type="Label" parent="."]
offset_top = 40.0
offset_right = 720.0
offset_bottom = 842.0
theme_override_colors/font_color = Color(0.147672, 0.147672, 0.147672, 1)
theme_override_fonts/font = ExtResource("3_er0oa")
theme_override_font_sizes/font_size = 35
text = "Space hornets are attacking!

How to play:
Each hornet has an assigned decimal
number. to break its defense, you
must enter the corresponding 
binary number on the panel below
and press enter.

The binary panel below has 8 \"bits\", 
each of which acts as a switch between
1 and 0.
8 bits allows you to write any number
between 0 and 255.

From right to left, their values
start with 1 and double every digit
(1, 2, 4, 8...).
Beginner's tip:
Switch on the bit with the highest
value that is less than the decimal
number first and make your way towards
the right."
horizontal_alignment = 1

